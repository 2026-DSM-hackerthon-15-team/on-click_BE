# Copy this file to .env and replace secrets before running Docker Compose.
COMPOSE_PROJECT_NAME=on-click

BACKEND_PORT=8080
POSTGRES_PORT=5432

POSTGRES_DB=onclick
POSTGRES_USER=onclick
POSTGRES_PASSWORD=change-me

JWT_SECRET=change-me-with-at-least-32-bytes
# Generate with: openssl rand -base64 32
# Required when INSTAGRAM_PROVIDER=http. Blank uses an ephemeral key for mock only.
INSTAGRAM_TOKEN_ENCRYPTION_KEY=
CORS_ALLOWED_ORIGINS=https://aaaaaa-ead.pages.dev,http://localhost:5173
AI_PROVIDER=mock
